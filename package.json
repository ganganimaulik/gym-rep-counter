{
  "name": "rep-counter-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prepare": "husky",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "prebuild": "expo prebuild --clean",
    "test": "jest",
    "coverage": "jest --coverage",
    "iphone-install": "node scripts/set-team-id.js && xcodebuild -workspace ios/repcounterapp.xcworkspace -scheme repcounterapp -configuration Release -destination 'id=00008130-000215120A8B803A' -allowProvisioningUpdates -derivedDataPath build && (xcrun devicectl device install app --device 00008130-000215120A8B803A build/Build/Products/Release-iphoneos/repcounterapp.app && xcrun devicectl device process launch --device 00008130-000215120A8B803A com.ganganimaulik.repcounterapp || true)",
    "rebuild": "bash scripts/rebuild.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-community/slider": "^5.0.1",
    "@react-native-google-signin/google-signin": "^16.0.0",
    "@react-native-picker/picker": "^2.11.2",
    "expo": "~54.0.10",
    "expo-av": "^16.0.7",
    "expo-background-timer": "^0.2.0",
    "expo-blur": "^15.0.7",
    "expo-build-properties": "^56.0.18",
    "expo-keep-awake": "^15.0.7",
    "expo-notifications": "~0.32.17",
    "expo-speech": "^14.0.7",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.9",
    "firebase": "^12.3.0",
    "lucide-react-native": "^0.544.0",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-chart-kit": "^6.12.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "^4.1.2",
    "react-native-svg": "^15.15.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "3.3.2",
    "workout-activity": "file:./modules/workout-activity",
    "workout-attributes": "file:./modules/workout-attributes"
  },
  "private": true,
  "devDependencies": {
    "@bacons/apple-targets": "^4.0.7",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29",
    "@types/react": "^19.2.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest": "^29",
    "jest-expo": "^54.0.12",
    "lint-staged": "^16.2.3",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
